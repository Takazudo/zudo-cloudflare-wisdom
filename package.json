{
  "name": "zudo-cloudflare-wisdom",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "// ── Doc site ────────────────────────────────────": "",
    "dev": "zfb dev",
    "build": "zfb build",
    "preview": "zfb preview",
    "check": "zfb check",
    "check:html": "html-validate \"dist/**/*.html\"",
    "check:links": "node scripts/check-links.js --strict-broken --allowlist=.check-links-allowlist",
    "check:pin-parity": "node scripts/check-pin-parity.mjs",
    "check:wrangler-pin": "node scripts/check-wrangler-pin.mjs",
    "check:template-drift": "bash scripts/check-template-drift.sh",
    "// ── Skill ───────────────────────────────────────": "",
    "setup:doc-skill": "bash scripts/setup-doc-skill.sh",
    "// ── Code quality ────────────────────────────────": "",
    "format:md": "pnpm dlx @takazudo/mdx-formatter --write 'src/content/**/*.{md,mdx}'",
    "format:md:check": "pnpm dlx @takazudo/mdx-formatter --check 'src/content/**/*.{md,mdx}'",
    "// ── Validation ──────────────────────────────────": "",
    "tags:audit": "tsx scripts/tags-audit.ts",
    "tags:suggest": "tsx scripts/tags-suggest.ts",
    "b4push": "bash scripts/run-b4push.sh"
  },
  "dependencies": {
    "@shikijs/transformers": "^4.0.0",
    "@takazudo/zfb": "0.1.0-next.36",
    "@takazudo/zfb-adapter-cloudflare": "0.1.0-next.36",
    "@takazudo/zfb-runtime": "0.1.0-next.36",
    "@takazudo/zudo-doc": "^0.2.0",
    "@takazudo/zudo-doc-history-server": "^0.2.0",
    "clsx": "^2.1.0",
    "diff": "^8.0.3",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.0",
    "katex": "^0.16.38",
    "mermaid": "^11.12.3",
    "minisearch": "^7.2.0",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.6",
    "remark-cjk-friendly": "^2.0.1",
    "remark-directive": "^3.0.0",
    "shiki": "^4.0.2",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@tailwindcss/vite": "^4.2.0",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.0.0",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.2.0",
    "@types/string-similarity": "^4.0.2",
    "create-zudo-doc": "0.2.0",
    "html-validate": "^10.0.0",
    "pagefind": "^1.4.0",
    "picocolors": "^1.1.1",
    "pluralize": "^8.0.0",
    "string-similarity": "^4.0.4",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "wrangler": "4.85.0"
  },
  "engines": {
    "node": ">=20.0"
  },
  "packageManager": "pnpm@10.6.5",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
