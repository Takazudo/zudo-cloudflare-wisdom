# that forwards the props to <SidebarTree>. zudolab/zudo-doc#1355 wave 13.5.
src/components/sidebar-toggle.tsx

# Theme-toggle island-collision fix — the host ThemeToggle and the package's
# ThemeToggle (pulled into the SSR graph via @takazudo/zudo-doc/header) share
# the name "ThemeToggle"; esbuild renames one to "ThemeToggle2", so the SSG
# emitted data-zfb-island="ThemeToggle2" with no matching client registry key
# → dead toggle. Production pins `ThemeToggle.displayName = "ThemeToggle"` so
# the island marker always matches the registered key. zudolab/zudo-doc#1446.
src/components/theme-toggle.tsx

